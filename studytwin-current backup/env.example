# ═══════════════════════════════════════════════════════════════
# StudyTwin Server — Environment Variables
# COPY this to .env and fill in your real values
# NEVER commit .env to GitHub
# ═══════════════════════════════════════════════════════════════

# ── Firebase ─────────────────────────────────────────────────────
FIREBASE_DATABASE_URL=https://studytwin-rvce-default-rtdb.asia-southeast1.firebasedatabase.app

# Download service account JSON from:
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the ENTIRE JSON as ONE single line below
# Quick command: node -e "console.log(JSON.stringify(require('./serviceAccount.json')))"
FIREBASE_SERVICE_ACCOUNT=PASTE_FULL_JSON_HERE_AS_ONE_LINE

# ── Kaggle ────────────────────────────────────────────────────────
# kaggle.com → Profile → Settings → API → Create New API Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
# From your notebook URL: kaggle.com/code/{username}/{notebook-name}
KAGGLE_KERNEL_SLUG=your_username/your-notebook-name

# ── Google Gemini AI (FREE — replaces Claude/Anthropic) ───────────
# FREE key at: https://aistudio.google.com/app/apikey
# No credit card. 1500 requests/day on Gemini 2.0 Flash
GEMINI_API_KEY=your_gemini_api_key_here

# ── Server ────────────────────────────────────────────────────────
PORT=3001
